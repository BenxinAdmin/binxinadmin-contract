# =========================================================
# BinxinAdmin · Docker 开发环境变量模板
# 用法：cp .env.example .env，按需调整后执行 docker compose up -d
# 注意：.env 已加入 .gitignore，绝对不要提交真实密码到仓库
# =========================================================

# ---- 全局 ----
COMPOSE_PROJECT_NAME=binxin
TZ=Asia/Shanghai

# ---- MySQL 8.0 ----
# 宿主机端口避让本地已有的 MySQL 9（3306）
MYSQL_PORT=3307
MYSQL_ROOT_PASSWORD=binxin_root_2026
MYSQL_DATABASE=binxinadmin
MYSQL_USER=binxin
MYSQL_PASSWORD=binxin_pass_2026

# ---- Redis 7.4 ----
# 宿主机端口避让本地已有的 Redis 8（6379）
REDIS_PORT=6380
# 留空则不启用密码；默认开启以贴近生产
REDIS_PASSWORD=binxin_redis_2026

# ---- Nginx ----
# TP 站点访问地址：http://localhost:${TP_PORT}
TP_PORT=8080
# Laravel 站点访问地址：http://localhost:${LARAVEL_PORT}
LARAVEL_PORT=8081

# ---- 后端项目挂载路径（相对 docker/ 目录） ----
# 目录约定：xinzhi/binxinadmin-contract/docker/ 与 backend 项目平级
# 所以相对路径是 ../../binxinadmin-backend-xxx
TP_PATH=../../binxinadmin-backend-tp
LARAVEL_PATH=../../binxinadmin-backend-laravel
