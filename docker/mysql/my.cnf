# =========================================================
# BinxinAdmin · MySQL 8.0 自定义配置
# 挂载到容器 /etc/mysql/conf.d/binxin.cnf
# 配合 docker-compose command 的 --default-authentication-plugin
# =========================================================

[mysqld]
# ---- 字符集与排序规则 ----
character-set-server         = utf8mb4
collation-server             = utf8mb4_unicode_ci
init-connect                 = 'SET NAMES utf8mb4'
skip-character-set-client-handshake = OFF

# ---- 时区 ----
default-time-zone            = '+08:00'

# ---- SQL 模式（不要 STRICT 太死，保持开发友好但仍校验关键项） ----
sql-mode = "STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,ERROR_FOR_DIVISION_BY_ZERO,NO_ZERO_DATE,NO_ZERO_IN_DATE"

# ---- 引擎与限制 ----
default-storage-engine       = InnoDB
max_allowed_packet           = 64M
max_connections              = 300
wait_timeout                 = 28800
interactive_timeout          = 28800
table_open_cache             = 2000
thread_cache_size            = 64

# ---- InnoDB（开发机适中配置） ----
innodb_buffer_pool_size      = 256M
innodb_log_buffer_size       = 16M
innodb_flush_log_at_trx_commit = 2
innodb_flush_method          = O_DIRECT
innodb_file_per_table        = 1
innodb_open_files            = 2000
innodb_io_capacity           = 1000

# ---- 日志（开发可开 slow log 观察性能） ----
slow_query_log               = 1
slow_query_log_file          = /var/lib/mysql/slow.log
long_query_time              = 2
log_queries_not_using_indexes = 0

[client]
default-character-set        = utf8mb4

[mysql]
default-character-set        = utf8mb4
